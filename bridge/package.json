{
  "name": "mocap-bridge",
  "version": "1.0.0",
  "description": "MoCap Studio WebSocket bridge - relays pose data from the browser capture app to Unreal Engine.",
  "main": "mocap-bridge.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZeroOneTwo-CreativeTechnologyHub/ue-mocap-studio"
  },
  "scripts": {
    "start": "node mocap-bridge.js",
    "build": "pkg mocap-bridge.js --targets node18-win-x64,node18-macos-arm64,node18-macos-x64,node18-linux-x64 --output dist/mocap-bridge",
    "build:win": "pkg mocap-bridge.js --targets node18-win-x64 --output dist/mocap-bridge-win",
    "build:mac-arm": "pkg mocap-bridge.js --targets node18-macos-arm64 --output dist/mocap-bridge-mac-arm64",
    "build:mac-intel": "pkg mocap-bridge.js --targets node18-macos-x64 --output dist/mocap-bridge-mac-x64",
    "build:linux": "pkg mocap-bridge.js --targets node18-linux-x64 --output dist/mocap-bridge-linux"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "outputPath": "dist"
  }
}
